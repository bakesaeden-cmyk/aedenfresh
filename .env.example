# ── Supabase ─────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Razorpay (M3+) ───────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── WhatsApp Cloud API (M5+) ─────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Any string you choose; must match the token entered in Meta App Dashboard
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Meta App Secret (App Dashboard → Settings → Basic) — signs inbound webhooks
WHATSAPP_APP_SECRET=
# Customer-facing WhatsApp number in international format, digits only
# Example: 919876543210 (used for the floating chat and footer links)
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Fallback operations number. Prefer setting stores.whatsapp_phone for each store.
STORE_WHATSAPP_DEFAULT_NUMBER=
# Approved Meta utility template for store dispatch notifications (recommended)
WHATSAPP_STORE_ORDER_TEMPLATE=
WHATSAPP_TEMPLATE_LANGUAGE=en

# ── ERP retail catalogue + order export ─────────────────────
# The pull endpoint must return the normalized contract documented in
# docs/ERP_INTEGRATION.md. Leave pull credentials empty if the ERP pushes data.
ERP_API_BASE_URL=
ERP_CATALOGUE_PATH=/catalogue
ERP_API_TOKEN=
ERP_API_AUTH_SCHEME=Bearer
ERP_API_KEY=
ERP_API_KEY_HEADER=X-API-Key
ERP_TIMEOUT_MS=15000
# Protects POST /api/integrations/erp/sync (x-erp-sync-secret header)
ERP_SYNC_SECRET=
# Paid orders are exported here with an Idempotency-Key header.
ERP_ORDER_WEBHOOK_URL=

# ── n8n (M4+) ────────────────────────────────────────────
# Shared secret for n8n → platform API calls
N8N_API_SECRET=
# n8n production webhook URLs (from the workflow trigger nodes)
N8N_WHATSAPP_WEBHOOK_URL=
N8N_PAYMENT_FAILED_WEBHOOK_URL=

# ── Platform ─────────────────────────────────────────────
# Public base URL (used in receipt/track links sent to customers)
PLATFORM_URL=http://localhost:3000
